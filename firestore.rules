rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && (request.auth.token.email_verified == true || request.auth.token.email == "rxtools1@gmail.com"); }
    function isAdmin() { return isSignedIn() && (request.auth.token.email == "rxtools1@gmail.com"); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // --- Validation Blueprints ---

    function isValidTool(data) {
      return data.keys().hasAll(['name', 'description', 'downloadUrl', 'imageUrl', 'section', 'createdAt', 'updatedAt'])
        && data.keys().size() == 7
        && data.name is string && data.name.size() >= 1 && data.name.size() <= 100
        && data.description is string && data.description.size() <= 5000
        && data.downloadUrl is string && data.downloadUrl.size() <= 1000
        && data.imageUrl is string && data.imageUrl.size() <= 1000
        && data.section is string && data.section in ['elite', 'fivem', 'spoofers', 'cheats', 'tweaks', 'grabbers']
        && data.createdAt is string
        && data.updatedAt is string;
    }

    function isValidSettings(data) {
      return data.keys().hasAll(['discordWebhookUrl', 'siteName', 'siteDescription'])
        && data.keys().size() == 3
        && data.discordWebhookUrl is string && data.discordWebhookUrl.size() <= 600
        && data.siteName is string && data.siteName.size() <= 150
        && data.siteDescription is string && data.siteDescription.size() <= 2000;
    }

    function isValidCategories(data) {
      return data.keys().hasAll(['list'])
        && data.keys().size() == 1
        && data.list is list && data.list.size() <= 50
        && (data.list.size() == 0 || data.list[0] is string);
    }

    // --- Collection Rules ---

    match /tools/{toolId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(toolId) && isValidTool(incoming());
      allow update: if isAdmin() && isValidId(toolId) && isValidTool(incoming())
        && incoming().createdAt == existing().createdAt; // Immutability
      allow delete: if isAdmin() && isValidId(toolId);
    }

    match /settings/config {
      allow read: if true;
      allow write: if isAdmin() && isValidSettings(incoming());
    }

    match /settings/categories {
      allow read: if true;
      allow write: if isAdmin() && isValidCategories(incoming());
    }
  }
}
